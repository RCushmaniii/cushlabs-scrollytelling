---
import { getCollection } from "astro:content";
import ScrollytellingLayout from "@/layouts/ScrollytellingLayout.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import ContentSection from "@/components/sections/ContentSection.astro";
import Fireflies from "@/components/effects/Fireflies.astro";
import GrainOverlay from "@/components/effects/GrainOverlay.astro";
import PresentationOverlay from "@/components/ui/PresentationOverlay.svelte";
import Navbar from "@/components/ui/Navbar.svelte";
import ProgressBar from "@/components/ui/ProgressBar.svelte";
import ScrollNav from "@/components/ui/ScrollNav.svelte";
import Lightbox from "@/components/ui/Lightbox.svelte";
import ShareButtons from "@/components/ui/ShareButtons.svelte";
import Footer from "@/components/ui/Footer.svelte";
import MatrixBackground from "@/components/effects/MatrixBackground.svelte";
import VideoBackground from "@/components/ui/VideoBackground.svelte";
import ImageBackground from "@/components/ui/ImageBackground.svelte";

const sections = (await getCollection("sections")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<ScrollytellingLayout>
  <PresentationOverlay slot="presentation-overlay" client:load />
  <ProgressBar slot="progress-bar" client:load />
  <Navbar slot="navbar" client:load />
  <ScrollNav slot="scroll-nav" client:load />
  <GrainOverlay slot="grain" />
  <Lightbox slot="lightbox" client:load />

  <VideoBackground slot="video-bg" src="/video/scrolly-intro.mp4" sectionId="hero" delay={1500} client:load />
  <VideoBackground slot="video-bg" src="/video/the-proof-background.mp4" sectionId="proof" client:load />
  <VideoBackground slot="video-bg" src="/video/formula1-solution.mp4" sectionId="solution" client:load />
  <ImageBackground slot="video-bg" src="/images/checkmate-problem.webp" sectionId="problem" client:visible />

  <Fireflies />
  <MatrixBackground client:load />

  {sections.map(async (section) => {
    const { Content } = await section.render();

    if (section.data.type === "hero") {
      return (
        <HeroSection id={section.data.id} backgroundImage={section.data.backgroundImage} transparent>
          <Content />
        </HeroSection>
      );
    }

    return (
      <ContentSection
        id={section.data.id}
        number={section.data.number}
        background={["proof", "problem", "solution"].includes(section.data.id) ? "transparent" : section.data.background}
      >
        <Content />
      </ContentSection>
    );
  })}

  <!-- Share + Footer -->
  <div class="relative z-[2] py-12 px-6 text-center" style="background: var(--color-background)">
    <p class="text-sm text-[var(--color-text-muted)] mb-4">
      <span data-lang="en" class="active">Share this presentation</span>
      <span data-lang="es">Comparte esta presentacion</span>
    </p>
    <div class="flex justify-center">
      <ShareButtons
        client:visible
        titleEn="CushLabs builds cinematic scrollytelling presentations — check this out"
        titleEs="CushLabs construye presentaciones cinematograficas de scrollytelling — mira esto"
      />
    </div>
  </div>
  <div class="relative z-[2]" style="background: var(--color-background)">
    <Footer client:visible />
  </div>
</ScrollytellingLayout>

---
interface Props {
  id: string;
  backgroundImage?: string;
}

const { id, backgroundImage } = Astro.props;
---

<section
  id={id}
  class="relative w-full min-h-screen flex items-center justify-center overflow-hidden"
>
  {backgroundImage && (
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style={`background-image: url('${backgroundImage}')`}
    >
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-background)]/60 via-[var(--color-background)]/40 to-[var(--color-background)]" />
    </div>
  )}

  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 text-center">
    <slot />
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float">
    <svg
      class="w-6 h-6 text-[var(--color-accent)] opacity-60"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"
      />
    </svg>
  </div>
</section>
